.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 24rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰 */
.header-decoration {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.dc1 {
  width: 200rpx;
  height: 200rpx;
  background: #07c160;
  top: 80rpx;
  right: 40rpx;
}

.dc2 {
  width: 120rpx;
  height: 120rpx;
  background: #ff6b35;
  top: 140rpx;
  right: 180rpx;
}

.dc3 {
  width: 80rpx;
  height: 80rpx;
  background: #ffd93d;
  top: 220rpx;
  right: 100rpx;
}

/* 标题区域 */
.header {
  margin-top: 60rpx;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  color: #2d3436;
  font-weight: 700;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #b2bec3;
}

/* 输入区域 */
.input-section {
  margin-bottom: 60rpx;
}

.input-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.input-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #636e72;
  font-weight: 500;
}

.input-field {
  width: 100%;
  font-size: 36rpx;
  color: #2d3436;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #dfe6e9;
  outline: none;
}

.input-placeholder {
  color: #b2bec3;
}

.input-count {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.count-text {
  font-size: 24rpx;
  color: #b2bec3;
}

/* 快捷标签 */
.quick-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
  padding: 0 8rpx;
}

.tag {
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  border: 2rpx solid #dfe6e9;
}

.tag:active {
  background-color: #e8f5e9;
  border-color: #07c160;
}

.tag-text {
  font-size: 26rpx;
  color: #636e72;
}

.tag:active .tag-text {
  color: #07c160;
}

/* 操作区域 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.create-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 50rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.create-btn.disabled {
  background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);
  box-shadow: none;
}

.create-btn-text {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
}

.create-btn.disabled .create-btn-text {
  color: #ffffff;
  opacity: 0.6;
}

.cancel-btn {
  padding: 24rpx;
  text-align: center;
}

.cancel-btn-text {
  font-size: 30rpx;
  color: #b2bec3;
}
