.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* 目标卡片 */
.goal-card {
  position: relative;
  width: 100%;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.25);
  box-sizing: border-box;
}

.card-glow {
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.goal-main {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.goal-icon-wrap {
  margin-right: 24rpx;
}

.goal-icon {
  width: 88rpx;
  height: 88rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background-color: #ffffff;
}

.goal-content {
  flex: 1;
}

.goal-title {
  display: block;
  font-size: 38rpx;
  color: #ffffff;
  font-weight: 700;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.goal-stats {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.stat-pill {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 12rpx 18rpx;
}

.stat-pill.secondary {
  background-color: rgba(255, 255, 255, 0.1);
}

.stat-fire {
  font-size: 22rpx;
  color: #ffd93d;
  margin-right: 4rpx;
}

.stat-value {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 700;
  margin-right: 4rpx;
}

.stat-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 通用区块卡片 */
.section-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-indicator {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 14rpx;
}

.section-indicator.green {
  background-color: #07c160;
}

.section-indicator.orange {
  background-color: #ff6b35;
}

.section-title {
  font-size: 32rpx;
  color: #2d3436;
  font-weight: 600;
}

/* 7天日历 */
.week-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.week-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.week-circle {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  transition: transform 0.2s ease;
}

.week-circle.done {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  box-shadow: 0 6rpx 16rpx rgba(7, 193, 96, 0.3);
}

.check-mark {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.week-day {
  font-size: 26rpx;
  color: #b2bec3;
  margin-bottom: 6rpx;
}

.week-date {
  font-size: 22rpx;
  color: #636e72;
}

/* 打卡记录 */
.records-wrap {
  width: 100%;
}

.record-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-row:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.record-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  margin-right: 20rpx;
}

.record-dot.active {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
}

.record-text {
  font-size: 28rpx;
  color: #333333;
}

.record-right {
  background-color: #f8f8f8;
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
}

.record-right.done {
  background-color: #e8f8f0;
}

.record-status {
  font-size: 22rpx;
  color: #999999;
}

.record-right.done .record-status {
  color: #07c160;
  font-weight: 500;
}

/* 返回按钮 */
.btn-back {
  width: 100%;
  background-color: #ffffff;
  border-radius: 48rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-top: 8rpx;
  box-sizing: border-box;
}

.btn-back:active {
  background-color: #f5f5f5;
}

.btn-back-text {
  font-size: 30rpx;
  color: #666666;
  font-weight: 500;
}
