<view class="container">
  <!-- 目标信息卡片 -->
  <view class="goal-card">
    <view class="card-glow"></view>
    <view class="goal-main">
      <view class="goal-icon-wrap">
        <view class="goal-icon">
          <view class="icon-dot"></view>
        </view>
      </view>
      <view class="goal-content">
        <text class="goal-title">{{goalName}}</text>
        <view class="goal-stats">
          <view class="stat-pill">
            <text class="stat-fire">*</text>
            <text class="stat-value">{{streak}}</text>
            <text class="stat-unit">天连续</text>
          </view>
          <view class="stat-pill secondary">
            <text class="stat-value">{{totalDays}}</text>
            <text class="stat-unit">次打卡</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 7天打卡日历 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-indicator green"></view>
      <text class="section-title">最近 7 天</text>
    </view>
    <view class="week-grid">
      <view class="week-item" wx:for="{{weekDays}}" wx:key="index">
        <view class="week-circle {{item.done ? 'done' : ''}}">
          <text wx:if="{{item.done}}" class="check-mark">*</text>
        </view>
        <text class="week-day">{{item.label}}</text>
        <text class="week-date">{{item.date}}</text>
      </view>
    </view>
  </view>

  <!-- 打卡记录 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-indicator orange"></view>
      <text class="section-title">打卡记录</text>
    </view>
    <view class="records-wrap">
      <view class="record-row" wx:for="{{records}}" wx:key="date">
        <view class="record-left">
          <view class="record-dot {{item.done ? 'active' : ''}}"></view>
          <text class="record-text">{{item.dateDisplay}}</text>
        </view>
        <view class="record-right {{item.done ? 'done' : ''}}">
          <text class="record-status">{{item.done ? '已完成' : '未打卡'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 返回首页 -->
  <view class="btn-back" bind:tap="goBack">
    <text class="btn-back-text">返回首页</text>
  </view>
</view>
